# Thermaltrue WMS — Environment Variables
# Copy this file to .env and adjust values

# Application
VITE_APP_TITLE=Thermaltrue WMS
VITE_TAURI_DEV_HOST=localhost

# PostgreSQL
DATABASE_URL=postgresql://postgres@localhost:5432/thermaltrue

# API / Tauri
TAURI_PUBLIC_KEY=  # Set for production updater (see src-tauri/tauri.conf.json)

# Error Tracking (optional)
VITE_SENTRY_DSN=  # https://xxxxx@sentry.io/xxxxx
