# Thermaltrue WMS — Environment Variables
# Copy this file to .env and adjust values for your environment

# ── Server ──
PORT=3000
CORS_ORIGIN=
JWT_SECRET=change-this-to-a-random-64-char-string
SESSION_TTL_HOURS=24
DATABASE_URL=postgresql://postgres:password@localhost:5432/thermaltrue?sslmode=disable
DATABASE_POOL_SIZE=10

# ── Server.exe static frontend (optional) ──
# Path to compiled frontend dist/; defaults to "../dist" relative to server.exe
# FRONTEND_DIST=/opt/thermaltrue/dist

# ── Logging ──
# RUST_LOG=info

# ── Default Admin ──
# Used only on first run when no users exist; auto-generated if not set
# DEFAULT_ADMIN_PASSWORD=MyS3cur3P@ss

# ── Tauri / Client ──
VITE_APP_TITLE=Thermaltrue WMS
VITE_TAURI_DEV_HOST=localhost
VITE_API_URL=http://localhost:3000
VITE_FORCE_HTTP=true

# ── Updater (optional) ──
# TAURI_PUBLIC_KEY=

# ── Error Tracking (optional) ──
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
