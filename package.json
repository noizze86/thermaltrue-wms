{
  "name": "thermaltrue",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "cap:dev": "node -e \"require('fs').copyFileSync('scripts/cap-templates/dev.json','src-tauri/capabilities/default.json')\"",
    "cap:prod": "node -e \"require('fs').copyFileSync('scripts/cap-templates/prod.json','src-tauri/capabilities/default.json')\"",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "test:e2e": "cd tests && npm install && npm run test:all",
    "test:e2e:dashboard": "cd tests && npm run test:dashboard",
    "test:e2e:master-data": "cd tests && npm run test:master-data",
    "test:e2e:transactions": "cd tests && npm run test:transactions",
    "test:e2e:warehouse": "cd tests && npm run test:warehouse",
    "test:e2e:analysis": "cd tests && npm run test:analysis",
    "test:e2e:reports": "cd tests && npm run test:reports",
    "test:e2e:settings": "cd tests && npm run test:settings",
    "test:e2e:negative": "cd tests && npm run test:negative"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@sentry/browser": "^10.63.0",
    "@sentry/react": "^10.63.0",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-barcode-scanner": "^2.4.5",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  }
}
