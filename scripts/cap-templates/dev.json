{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Development capability — localhost only",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "updater:default",
    "notification:default",
    "process:default",
    "barcode-scanner:default",
    "log:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:3000" },
        { "url": "https://localhost:3443" }
      ]
    }
  ]
}
