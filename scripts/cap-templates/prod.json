{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Production capability — localhost + LAN IP",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "updater:default",
    "notification:default",
    "process:default",
    "barcode-scanner:default",
    "log:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:3000" },
        { "url": "http://localhost:3001" },
        { "url": "http://localhost:3002" },
        { "url": "http://*:8000/**" },
        { "url": "https://localhost:3443" },
        { "url": "https://*:443/**" },
        { "url": "https://*:8443/**" },
        { "url": "https://*:**" }
      ]
    }
  ]
}
