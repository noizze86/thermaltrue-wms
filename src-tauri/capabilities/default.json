{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability — enables permissions for Thermaltrue WMS",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "updater:default",
    "notification:default",
    "process:default",
    "barcode-scanner:default",
    "log:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://localhost:3000" }]
    }
  ]
}
